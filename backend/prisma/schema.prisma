generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  password    String
  role        String   @default("user")
  permissions String?  @default("{}")
}

model Supplier {
  id              Int       @id @default(autoincrement())
  name            String
  createdAt       DateTime  @default(now())
  paymentTermDays Int       @default(0)
  invoices        Invoice[]
  payments        Payment[]
  cheques         Cheque[]
}

model Invoice {
  id          Int      @id @default(autoincrement())
  supplierId  Int
  amount      Decimal 
  paidAmount  Decimal  @default(0)
  dueDate     DateTime
  createdAt   DateTime @default(now())
  invoiceDate DateTime @default(now())
  description String?
  reminder    Boolean  @default(false)
  reminderAmount Decimal?
  reminderBaseline Decimal @default(0)
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  payments    Payment[]
  cheques     Cheque[]
}

model Payment {
  id          Int      @id @default(autoincrement())
  supplierId  Int
  amount      Decimal 
  createdAt   DateTime @default(now())
  paymentDate DateTime @default(now())
  accountId   Int
  invoiceId   Int?
  account     Account  @relation(fields: [accountId], references: [id])
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model Account {
  id          Int          @id @default(autoincrement())
  name        String
  type        String
  balance     Decimal      @default(0)
  createdAt   DateTime     @default(now())
  collections Collection[]
  payments    Payment[]
  adjustments AccountAdjustment[]
  cheques     Cheque[]
  expenses    Expense[]
}

model AccountAdjustment {
  id              Int      @id @default(autoincrement())
  accountId       Int
  amount          Decimal 
  systemBalance   Decimal 
  actualBalance   Decimal 
  note            String?
  createdAt       DateTime @default(now())
  account         Account  @relation(fields: [accountId], references: [id])
}

model Collection {
  id           Int       @id @default(autoincrement())
  amount       Decimal 
  currency     String
  exchangeRate Decimal   @default(1)
  amountInBase Decimal
  accountId    Int
  note         String
  expectedDate DateTime?
  receivedDate DateTime
  status       String    @default("received")
  createdAt    DateTime  @default(now())
  account      Account   @relation(fields: [accountId], references: [id])
}

model Cheque {
  id          Int      @id @default(autoincrement())
  amount      Decimal
  chequeDate  DateTime
  status      String   @default("Pending") // Pending, Cleared, Bounced
  accountId   Int
  supplierId  Int?
  invoiceId   Int?
  note        String?
  createdAt   DateTime @default(now())
  
  account     Account   @relation(fields: [accountId], references: [id])
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])
}
model Expense {
  id          Int      @id @default(autoincrement())
  category    String
  amount      Decimal 
  paidAmount  Decimal  @default(0)
  accountId   Int
  account     Account  @relation(fields: [accountId], references: [id])
  date        DateTime
  note        String?
  reminder    Boolean  @default(false)
  createdAt   DateTime @default(now())
}
