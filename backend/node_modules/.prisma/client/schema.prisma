generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  password    String
  role        String   @default("user")
  permissions String?  @default("{}")
}

model Supplier {
  id              Int       @id @default(autoincrement())
  name            String
  priority        Int
  createdAt       DateTime  @default(now())
  paymentTermDays Int       @default(0)
  invoices        Invoice[]
  payments        Payment[]
}

model Invoice {
  id               Int       @id @default(autoincrement())
  supplierId       Int
  amount           Decimal
  paidAmount       Decimal   @default(0)
  dueDate          DateTime
  createdAt        DateTime  @default(now())
  invoiceDate      DateTime  @default(now())
  description      String?
  reminder         Boolean   @default(false)
  reminderAmount   Decimal?
  reminderBaseline Decimal   @default(0)
  supplier         Supplier  @relation(fields: [supplierId], references: [id])
  payments         Payment[]
}

model Payment {
  id          Int      @id @default(autoincrement())
  supplierId  Int
  amount      Decimal
  createdAt   DateTime @default(now())
  paymentDate DateTime @default(now())
  accountId   Int
  invoiceId   Int?
  account     Account  @relation(fields: [accountId], references: [id])
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model Account {
  id          Int                 @id @default(autoincrement())
  name        String
  type        String
  balance     Decimal             @default(0)
  createdAt   DateTime            @default(now())
  collections Collection[]
  payments    Payment[]
  adjustments AccountAdjustment[]
}

model AccountAdjustment {
  id            Int      @id @default(autoincrement())
  accountId     Int
  amount        Decimal
  systemBalance Decimal
  actualBalance Decimal
  note          String?
  createdAt     DateTime @default(now())
  account       Account  @relation(fields: [accountId], references: [id])
}

model Collection {
  id           Int       @id @default(autoincrement())
  amount       Decimal
  currency     String
  exchangeRate Decimal   @default(1)
  amountInBase Decimal
  accountId    Int
  note         String
  expectedDate DateTime?
  receivedDate DateTime
  status       String    @default("received")
  createdAt    DateTime  @default(now())
  account      Account   @relation(fields: [accountId], references: [id])
}
